generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Finance ──────────────────────────────────────────────────────────────────

enum AccountType {
  CHECKING
  SAVINGS
  CASH
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Account {
  id           String        @id @default(cuid())
  name         String
  type         AccountType
  currency     String        @default("CZK")
  balance      Float         @default(0)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Category {
  id           String          @id @default(cuid())
  name         String
  type         CategoryType
  color        String          @default("#6366f1")
  icon         String          @default("tag")
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id               String          @id @default(cuid())
  accountId        String
  categoryId       String
  amount           Float
  type             TransactionType
  description      String?
  date             DateTime
  createdAt        DateTime        @default(now())
  externalId       String?
  importId         String?         @unique
  importSource     String?
  originalCurrency String?
  originalAmount   Float?
  exchangeRate     Float?
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category         Category        @relation(fields: [categoryId], references: [id])

  @@index([externalId])
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String
  amount     Float
  month      DateTime
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, month])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String   @default("CZK")
  rate         Float
  date         String
  source       String   @default("ECB")
  fetchedAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency, date])
}

model NetWorthSnapshot {
  id               Int      @id @default(autoincrement())
  date             DateTime @db.Date
  cashTotal        Decimal  @db.Decimal(12, 2)
  investmentsTotal Decimal  @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())

  @@unique([date])
}

// ─── Investments ──────────────────────────────────────────────────────────────

enum AssetType {
  CRYPTO
  REAL_ESTATE
  GOLD_SILVER
  OTHER
}

enum PriceSource {
  MANUAL
  API
}

enum CryptoTxType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  REWARD
  SWAP
}

enum PurchaseType {
  BUY
  SELL
}

model Asset {
  id                 String              @id @default(cuid())
  name               String
  ticker             String
  type               AssetType
  currency           String              @default("CZK")
  purchases          Purchase[]
  prices             AssetPrice[]
  cryptoTransactions CryptoTransaction[]
}

model Purchase {
  id           String       @id @default(cuid())
  assetId      String
  type         PurchaseType @default(BUY)
  date         DateTime
  quantity     Float
  pricePerUnit Float
  fees         Float        @default(0)
  notes        String?
  accountId    String?
  createdAt    DateTime     @default(now())
  externalId   String?
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([externalId])
}

model AssetPrice {
  id        String      @id @default(cuid())
  assetId   String
  price     Float
  source    PriceSource @default(MANUAL)
  fetchedAt DateTime    @default(now())
  asset     Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model CryptoTransaction {
  id           String       @id @default(cuid())
  assetId      String
  type         CryptoTxType
  date         DateTime
  quantity     Float        // positive = receive, negative = spend
  pricePerUnit Float?       // in CZK; null for deposits/withdrawals/rewards
  totalCZK     Float?       // total value in CZK at time of transaction
  fee          Float?
  feeCurrency  String?
  source       String       // BINANCE | COINMATE_ORDERS | COINMATE_HISTORY | CRYPTO_COM
  sourceId     String?      // original ID for dedup
  notes        String?
  createdAt    DateTime     @default(now())
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([source, sourceId])
  @@index([assetId])
  @@index([date])
}
